<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_bg_accent"
    android:padding="10dp">

    <TextView
        android:id="@+id/tvWidgetLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#AA000000"
        android:textSize="10sp"
        android:layout_marginBottom="2dp" />

    <TextView
        android:id="@+id/tvWidgetTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--:--"
        android:textColor="#FF1A1A1A"
        android:textSize="36sp"
        android:fontFamily="monospace"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvWidgetInterval"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Таймер"
        android:textColor="#CC000000"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="2dp" />

    <ProgressBar
        android:id="@+id/progressWidget"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="6dp"
        android:progressTint="#CC000000"
        android:progressBackgroundTint="#44000000"
        android:max="100"
        android:progress="0" />

</LinearLayout>
