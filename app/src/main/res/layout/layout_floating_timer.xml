<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floatingRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_floating"
    android:padding="12dp"
    android:minWidth="140dp">

    <TextView
        android:id="@+id/tvOverlayName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Интервал"
        android:textColor="#FFFFFFFF"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvOverlayTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5:00"
        android:textColor="#FF4CAF82"
        android:textSize="28sp"
        android:fontFamily="sans-serif-light" />

    <ProgressBar
        android:id="@+id/overlayProgress"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:progressTint="#FF4CAF82"
        android:progressBackgroundTint="#44FFFFFF"
        android:max="100"
        android:progress="0"
        android:layout_marginTop="6dp" />

</LinearLayout>
